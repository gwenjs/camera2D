{
  "name": "@gwenjs/camera2d",
  "version": "0.1.0",
  "description": "Camera2D plugin for GWEN",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gwenjs/camera2D"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./module": {
      "types": "./dist/module.d.ts",
      "import": "./dist/module.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@gwenjs/camera-core": "0.1.2",
    "@gwenjs/core": "0.2.2",
    "@gwenjs/kit": "0.2.1",
    "@gwenjs/math": "0.1.1",
    "@gwenjs/renderer-core": "0.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "happy-dom": "^18.0.0",
    "oxfmt": "latest",
    "oxlint": "latest",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitepress": "latest",
    "vitest": "^4.0.0"
  }
}
